        SVMarker.Size = UDim2.new(0, 10, 0, 10); SVMarker.BackgroundColor3 = Color3.fromRGB(255,255,255)
        SVMarker.BorderSizePixel = 0; SVMarker.ZIndex = 10000
        Instance.new("UICorner", SVMarker).CornerRadius = UDim.new(1, 0)
        local SVMs = Instance.new("UIStroke", SVMarker)
        SVMs.Color = Color3.fromRGB(0,0,0); SVMs.Thickness = 1.5

        -- Hue slider vertical
        local HueTrack = Instance.new("ImageLabel", PickerFrame)
        HueTrack.Size = UDim2.new(0, 18, 0, 140); HueTrack.Position = UDim2.new(0, 216, 0, 30)
        HueTrack.Image = "rbxassetid://2615689005" -- On va dessiner le dégradé via UIGradient
        HueTrack.BackgroundColor3 = Color3.fromRGB(255,255,255)
        HueTrack.BorderSizePixel = 0; HueTrack.ZIndex = 9999
        HueTrack.Image = "" -- on utilise UIGradient
        Instance.new("UICorner", HueTrack).CornerRadius = UDim.new(0, 4)
        local HueGrad = Instance.new("UIGradient", HueTrack)
        HueGrad.Rotation = 90
        HueGrad.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0,    Color3.fromHSV(0,   1, 1)),
            ColorSequenceKeypoint.new(0.17, Color3.fromHSV(0.17,1, 1)),
            ColorSequenceKeypoint.new(0.33, Color3.fromHSV(0.33,1, 1)),
            ColorSequenceKeypoint.new(0.5,  Color3.fromHSV(0.5, 1, 1)),
            ColorSequenceKeypoint.new(0.67, Color3.fromHSV(0.67,1, 1)),
            ColorSequenceKeypoint.new(0.83, Color3.fromHSV(0.83,1, 1)),
            ColorSequenceKeypoint.new(1,    Color3.fromHSV(1,   1, 1)),
        })

        -- Marqueur Hue
        local HueMarker = Instance.new("Frame", HueTrack)
        HueMarker.Size = UDim2.new(1, 2, 0, 4); HueMarker.Position = UDim2.new(0, -1, 0, 0)
        HueMarker.BackgroundColor3 = Color3.fromRGB(255,255,255); HueMarker.BorderSizePixel = 0; HueMarker.ZIndex = 10000
        Instance.new("UICorner", HueMarker).CornerRadius = UDim.new(0, 2)
        Instance.new("UIStroke", HueMarker).Color = Color3.fromRGB(0,0,0)

        -- Aperçu + hex bas
        local BottomRow = Instance.new("Frame", PickerFrame)
        BottomRow.Size = UDim2.new(1, -16, 0, 28); BottomRow.Position = UDim2.new(0, 8, 0, 178)
        BottomRow.BackgroundTransparency = 1; BottomRow.ZIndex = 9999

        local ColorPreview = Instance.new("Frame", BottomRow)
        ColorPreview.Name = "PreviewColor"
        ColorPreview.Size = UDim2.new(0, 28, 1, 0); ColorPreview.Position = UDim2.new(0, 0, 0, 0)
        ColorPreview.BackgroundColor3 = currentColor; ColorPreview.BorderSizePixel = 0; ColorPreview.ZIndex = 9999
        Instance.new("UICorner", ColorPreview).CornerRadius = UDim.new(0, 5)
        Instance.new("UIStroke", ColorPreview).Color = Color3.fromRGB(80,75,100)

        local HexBG2 = Instance.new("Frame", BottomRow)
        HexBG2.Size = UDim2.new(1, -36, 1, 0); HexBG2.Position = UDim2.new(0, 34, 0, 0)
        HexBG2.BackgroundColor3 = Color3.fromRGB(20, 18, 28); HexBG2.BorderSizePixel = 0; HexBG2.ZIndex = 9999
        Instance.new("UICorner", HexBG2).CornerRadius = UDim.new(0, 5)
        Instance.new("UIStroke", HexBG2).Color = Color3.fromRGB(80, 60, 100)
        local HexIn2 = Instance.new("TextBox", HexBG2)
        HexIn2.Size = UDim2.new(1, -8, 1, 0); HexIn2.Position = UDim2.new(0, 4, 0, 0)
        HexIn2.BackgroundTransparency = 1; HexIn2.PlaceholderText = "#rrggbb"
        HexIn2.PlaceholderColor3 = Color3.fromRGB(80, 70, 100)
        HexIn2.Text = color3ToHex(currentColor); HexIn2.Font = Enum.Font.GothamBold; HexIn2.TextSize = 11
        HexIn2.TextColor3 = Color3.fromRGB(238, 236, 242); HexIn2.ClearTextOnFocus = false; HexIn2.ZIndex = 9999

        -- État picker
        local hue, sat, val2 = Color3.toHSV(currentColor)
        local svDragging   = false
        local hueDragging  = false

        local function updateFromHSV()
            local c = Color3.fromHSV(hue, sat, val2)
            ColorPreview.BackgroundColor3 = c
            HexIn2.Text = color3ToHex(c)
            -- Mettre à jour SV2D background color (teinte pure)
            SV2D.BackgroundColor3 = Color3.fromHSV(hue, 1, 1)
            applyColor(c)
        end

        local function updateSVMarker()
            SVMarker.Position = UDim2.new(sat, -5, 1-val2, -5)
        end
        local function updateHueMarker()
            HueMarker.Position = UDim2.new(0, -1, hue, -2)
        end

        -- Init position des marqueurs
        updateSVMarker(); updateHueMarker()
        SV2D.BackgroundColor3 = Color3.fromHSV(hue, 1, 1)

        -- SV2D interaction
        local function onSVInput(inputPos)
            local abs2 = SV2D.AbsolutePosition
            local sz   = SV2D.AbsoluteSize
            sat  = math.clamp((inputPos.X - abs2.X) / sz.X, 0, 1)
            val2 = math.clamp(1 - (inputPos.Y - abs2.Y) / sz.Y, 0, 1)
            updateSVMarker(); updateFromHSV()
        end
        SV2D.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then
                svDragging = true; onSVInput(i.Position)
            end
        end)
        SV2D.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then svDragging = false end
        end)

        -- Hue interaction
        local function onHueInput(inputPos)
            local abs2 = HueTrack.AbsolutePosition
            local sz   = HueTrack.AbsoluteSize
            hue = math.clamp((inputPos.Y - abs2.Y) / sz.Y, 0, 1)
            updateHueMarker(); updateFromHSV()
        end
        HueTrack.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then
                hueDragging = true; onHueInput(i.Position)
            end
        end)
        HueTrack.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then hueDragging = false end
        end)

        -- Mouse move global
        local moveConn = UserInputService.InputChanged:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseMovement then
                if svDragging  then onSVInput(i.Position)  end
                if hueDragging then onHueInput(i.Position)  end
            end
        end)
        PickerFrame.AncestryChanged:Connect(function()
            if not PickerFrame.Parent then moveConn:Disconnect() end
        end)

        -- Hex input dans picker
        HexIn2.FocusLost:Connect(function()
            local c = hexToColor3(HexIn2.Text)
            if c then
                hue, sat, val2 = Color3.toHSV(c)
                updateSVMarker(); updateHueMarker(); updateFromHSV()
            end
        end)
    end

    Preview.MouseButton1Click:Connect(openPicker)

    -- Hex input direct (sans ouvrir picker)
    HexInput.FocusLost:Connect(function()
        local c = hexToColor3(HexInput.Text)
        if c then applyColor(c) end
    end)

    applyColor(currentColor)
    return CP
end

