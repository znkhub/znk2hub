    HexInput.PlaceholderText = "#ff0000"; HexInput.PlaceholderColor3 = Color3.fromRGB(80, 70, 100)
    HexInput.Text = ""; HexInput.Font = Enum.Font.GothamBold; HexInput.TextSize = 10
    HexInput.TextColor3 = Color3.fromRGB(238, 236, 242); HexInput.ClearTextOnFocus = false

    -- Popup picker
    local pickerOpen = false
    local PickerFrame = nil

    local function hexToColor3(hex)
        hex = hex:gsub("#", ""):gsub("%s", "")
        if #hex ~= 6 then return nil end
        local r = tonumber(hex:sub(1,2), 16)
        local g = tonumber(hex:sub(3,4), 16)
        local b = tonumber(hex:sub(5,6), 16)
        if r and g and b then return Color3.fromRGB(r, g, b) end
        return nil
    end
    local function color3ToHex(c)
        return string.format("%02x%02x%02x", math.floor(c.R*255), math.floor(c.G*255), math.floor(c.B*255))
    end

    local function applyColor(c)
        if not c then return end
        currentColor = c
        settings[settingKey] = c
        Preview.BackgroundColor3 = c
        HexInput.Text = color3ToHex(c)
        if callback then callback(c) end
        -- Mettre à jour le picker si ouvert
        if PickerFrame and PickerFrame.Parent then
            local sv2d = PickerFrame:FindFirstChild("SV2D")
            if sv2d then
                local h, s, v = Color3.toHSV(c)
                local previewFull = sv2d:FindFirstChild("PreviewColor")
                if previewFull then previewFull.BackgroundColor3 = c end
            end
        end
    end

