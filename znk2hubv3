-- ============================================================
-- RUNSERVICE LOOP (Aimbot + ESP Update + Rainbow + Keybinds)
-- ============================================================
local prevKeys = {}

local function isKeyJustPressed(kc)
    local now = UserInputService:IsKeyDown(kc)
    local prev = prevKeys[kc] or false
    return now and not prev
end

local espUpdateTimer = 0
local hlUpdateTimer  = 0

table.insert(connections, RunService.RenderStepped:Connect(function(dt)
    -- Keybind minimize
    if settings.minimizeKeyCode and UserInputService:IsKeyDown(settings.minimizeKeyCode) then
        if not prevKeys[settings.minimizeKeyCode] then toggleMinimize() end
    end
    prevKeys[settings.minimizeKeyCode or Enum.KeyCode.RightControl] = settings.minimizeKeyCode and UserInputService:IsKeyDown(settings.minimizeKeyCode)

    -- Keybinds features
    local keyMap = {
        {enabled="bindESP",       key="bindESPKey",       setting="redESP",       cb=function(v) updateESP() end},
        {enabled="bindHighlight",  key="bindHighlightKey", setting="highlightESP", cb=function(v) updateHighlightESP() end},
        {enabled="bindAimbot",     key="bindAimbotKey",    setting="aimbot",       cb=nil},
        {enabled="bindSpeed",      key="bindSpeedKey",     setting="speedEnabled", cb=function(v) if humanoid then humanoid.WalkSpeed = v and settings.walkSpeed or originalValues.walkSpeed end end},
        {enabled="bindFly",        key="bindFlyKey",       setting="fly",          cb=function(v) if v then startFly() end end},
        {enabled="bindNoclip",     key="bindNoclipKey",    setting="noclip",       cb=nil},
        {enabled="bindInfJump",    key="bindInfJumpKey",   setting="infiniteJump", cb=nil},
        {enabled="bindSpinbot",    key="bindSpinbotKey",   setting="spinbot",      cb=nil},
        {enabled="bindFullbright", key="bindFullbrightKey",setting="fullbright",   cb=function(v) local l=game:GetService("Lighting"); if v then l.Brightness=10; l.ClockTime=14 end end},
        {enabled="bindNoFog",      key="bindNoFogKey",     setting="noFog",        cb=function(v) local l=game:GetService("Lighting"); if v then l.FogEnd=100000; l.FogStart=99999 end end},
        {enabled="bindThirdPerson",key="bindThirdPersonKey",setting="thirdPerson", cb=nil},
        {enabled="bindAntiAFK",    key="bindAntiAFKKey",   setting="antiAFK",      cb=nil},
    }
    for _, km in ipairs(keyMap) do
        if settings[km.enabled] and settings[km.key] then
            local kc = settings[km.key]
            if UserInputService:IsKeyDown(kc) and not (prevKeys[kc]) then
                settings[km.setting] = not settings[km.setting]
                if km.cb then km.cb(settings[km.setting]) end
                -- Mettre à jour les toggles UI
                for _, rec in ipairs(toggleRegistry) do
                    if rec.settingKey == km.setting then
                        local v = settings[km.setting]
                        TweenService:Create(rec.button, TweenInfo.new(0.2), {
                            BackgroundColor3 = v and currentTheme or Color3.fromRGB(45, 45, 55)
                        }):Play()
                        TweenService:Create(rec.circle, TweenInfo.new(0.2), {
                            Position = v and UDim2.new(1,-19,0.5,-8.5) or UDim2.new(0,2,0.5,-8.5)
                        }):Play()
                        rec.enabled = v
                    end
                end
            end
            prevKeys[kc] = UserInputService:IsKeyDown(kc)
        end
    end

    -- ESP Update timer
    espUpdateTimer = espUpdateTimer + dt
    if espUpdateTimer >= 1 then
        espUpdateTimer = 0
        if settings.redESP or settings.rainbowESP then updateESP() end
        if settings.highlightESP then updateHighlightESP() end
    end

    -- Rainbow ESP rectangles
    if settings.rainbowESP then
        rainbowHue = (rainbowHue + dt * 0.3) % 1
        local rColor = Color3.fromHSV(rainbowHue, 1, 1)
        for _, h in pairs(highlights) do
            local box = h:FindFirstChildOfClass("Frame")
            if box then
                local stroke = box:FindFirstChildOfClass("UIStroke")
                if stroke then stroke.Color = rColor end
            end
        end
    end

    -- Rainbow Highlight ESP
    if settings.highlightRainbow then
        rainbowHue = (rainbowHue + dt * 0.3) % 1
        local rColor = Color3.fromHSV(rainbowHue, 1, 1)
        for _, hl in pairs(hlObjects) do
            if hl and hl.Parent then
                hl.FillColor = rColor
            end
        end
    end

    -- FOV Circle position
    if fovCircle then
        pcall(function()
            fovCircle.Position = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)
        end)
    end

    -- Aimbot
    if settings.aimbot then
        local target = lockedTarget
        if settings.aimbotLock and isAimbotLockHeld then
            if not target then target = getClosestTarget(); lockedTarget = target end
        elseif not settings.aimbotLock then
            target = getClosestTarget()
        end
        if target then
            local targetPos = target.Position
            local dir = (targetPos - camera.CFrame.Position).Unit
            camera.CFrame = camera.CFrame:Lerp(
                CFrame.new(camera.CFrame.Position, camera.CFrame.Position + dir),
                dt * (20 - settings.aimbotSmooth + 1)
            )
        else
            lockedTarget = nil
        end
    end

    -- Noclip
    if settings.noclip and character then
        for _, part in pairs(character:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    end

    -- Infinite Jump
    if settings.infiniteJump and humanoid then
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) and humanoid:GetState() == Enum.HumanoidStateType.Freefall then
            humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        end
    end

    -- Spinbot
    if settings.spinbot and rootpart then
        spinAngle = (spinAngle + settings.spinSpeed) % 360
        rootpart.CFrame = CFrame.new(rootpart.Position) * CFrame.Angles(0, math.rad(spinAngle), 0)
    end

    -- Update timer display
    updateRemainingTimeDisplay()
    if TimerLbl then TimerLbl.Text = currentKeyRemaining ~= "" and currentKeyRemaining or "Illimitée" end
    if UsernameLbl then UsernameLbl.Text = "👤 "..loggedUsername.." · "..currentKeyRemaining end
end))

