_G.ZNK_RefreshAllToggles = function()
    for _, rec in ipairs(toggleRegistry) do
        if rec.settingKey then
            local v = settings[rec.settingKey]
            rec.enabled = v
            TweenService:Create(rec.button, TweenInfo.new(0.2), {
                BackgroundColor3 = v and currentTheme or Color3.fromRGB(45, 45, 55)
            }):Play()
            TweenService:Create(rec.circle, TweenInfo.new(0.2), {
                Position = v and UDim2.new(1,-19,0.5,-8.5) or UDim2.new(0,2,0.5,-8.5)
            }):Play()
            if v and rec.callback then pcall(rec.callback, v) end
        end
    end
    -- Réappliquer ESP & Highlight si actifs
    if settings.redESP or settings.rainbowESP then updateESP() end
    if settings.highlightESP then updateHighlightESP() end
    if settings.showFOV then updateFOVCircle() end
    if settings.fly then startFly() end
    if humanoid then
        if settings.speedEnabled then humanoid.WalkSpeed = settings.walkSpeed end
        humanoid.JumpPower = settings.jumpPower
    end
    if settings.fovChanger then camera.FieldOfView = settings.fovValue end
    notify("ZNK Hub", "Sauvegarde chargée pour " .. loggedUsername, 3)
end

