local function createSlider(tabName, textKey, settingKey, min, max, suffix, callback)
    local default = settings[settingKey] or min
    local S = Instance.new("Frame", Content)
    S.Size = UDim2.new(1, 0, 0, 58); S.BackgroundColor3 = panelSoft
    S.BorderSizePixel = 0; S.Visible = (tabName == currentTab)
    Instance.new("UICorner", S).CornerRadius = UDim.new(0, 8)
    table.insert(tabPages[tabName], S)
    local Lbl = Instance.new("TextLabel", S)
    Lbl.Size = UDim2.new(0.65, 0, 0, 18); Lbl.Position = UDim2.new(0, 12, 0, 8)
    Lbl.BackgroundTransparency = 1; Lbl.Text = textKey; Lbl.Font = Enum.Font.GothamBold
    Lbl.TextSize = 13; Lbl.TextColor3 = Color3.fromRGB(238, 236, 242); Lbl.TextXAlignment = Enum.TextXAlignment.Left
    local ValBox = Instance.new("TextLabel", S)
    ValBox.Size = UDim2.new(0, 55, 0, 18); ValBox.Position = UDim2.new(1, -63, 0, 8)
    ValBox.BackgroundColor3 = Color3.fromRGB(34, 26, 43)
    ValBox.Text = tostring(default)..(suffix or ""); ValBox.Font = Enum.Font.GothamBold
    ValBox.TextSize = 11; ValBox.TextColor3 = currentTheme
    Instance.new("UICorner", ValBox).CornerRadius = UDim.new(0, 5)
    local Track = Instance.new("Frame", S)
    Track.Size = UDim2.new(1, -24, 0, 5); Track.Position = UDim2.new(0, 12, 1, -16)
    Track.BackgroundColor3 = Color3.fromRGB(48, 45, 58); Track.BorderSizePixel = 0
    Instance.new("UICorner", Track).CornerRadius = UDim.new(1, 0)
    local Fill = Instance.new("Frame", Track)
    Fill.Size = UDim2.new((default-min)/(max-min), 0, 1, 0)
    Fill.BackgroundColor3 = currentTheme; Fill.BorderSizePixel = 0
    Instance.new("UICorner", Fill).CornerRadius = UDim.new(1, 0)
    local Knob = Instance.new("Frame", Track)
    Knob.Size = UDim2.new(0, 14, 0, 14)
    Knob.Position = UDim2.new((default-min)/(max-min), -7, 0.5, -7)
    Knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255); Knob.BorderSizePixel = 0
    Instance.new("UICorner", Knob).CornerRadius = UDim.new(1, 0)
    local dragging = false
    local function updateSlider(inputX)
        local trackAbs = Track.AbsolutePosition.X
        local trackWidth = Track.AbsoluteSize.X
        local ratio = math.clamp((inputX - trackAbs) / trackWidth, 0, 1)
        local val = math.floor(min + ratio * (max - min))
        settings[settingKey] = val
        ValBox.Text = tostring(val)..(suffix or "")
        Fill.Size = UDim2.new(ratio, 0, 1, 0)
        Knob.Position = UDim2.new(ratio, -7, 0.5, -7)
        if callback then callback(val) end
    end
    Track.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; updateSlider(i.Position.X) end end)
    Track.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then updateSlider(i.Position.X) end
    end)
    return S
end

