        -- Image Roblox standard pour SV picker (blanc->couleur horizontalement, blanc->noir verticalement)
        SV2D.Image = "rbxassetid://2615689005"; -- SV gradient standard
        Instance.new("UICorner", SV2D).CornerRadius = UDim.new(0, 6)

        -- Marqueur SV
