-- ============================================================
-- SÉRIALISATION / DÉSÉRIALISATION DES SETTINGS
-- (pour sauvegarde par compte)
-- ============================================================
local function serializeSettings()
    local out = {}
    for k, v in pairs(settings) do
        if type(v) == "Color3" then
            out[k] = {_type="Color3", r=v.R, g=v.G, b=v.B}
        elseif type(v) == "EnumItem" then
            out[k] = {_type="EnumItem", val=tostring(v)}
        else
            out[k] = v
        end
    end
    return out
end

local function deserializeSettings(data)
    if not data then return end
    for k, v in pairs(data) do
        if type(v) == "table" then
            if v._type == "Color3" then
                settings[k] = Color3.new(v.r or 0, v.g or 0, v.b or 0)
            elseif v._type == "EnumItem" then
                pcall(function()
                    local enumStr = v.val or ""
                    -- ex: "Enum.KeyCode.F1"
                    local enumName = enumStr:match("Enum%.(%w+)%.(.+)")
                    if not enumName then
                        local a, b2 = enumStr:match("Enum%.(%w+)%.(.+)")
                        if a and b2 then settings[k] = Enum[a][b2] end
                    else
                        local parts = {}
                        for p in enumStr:gmatch("[^%.]+") do table.insert(parts, p) end
                        -- parts = {"Enum","KeyCode","F1"}
                        if #parts == 3 then
                            settings[k] = Enum[parts[2]][parts[3]]
                        end
                    end
                end)
            end
        else
            if settings[k] ~= nil then
                settings[k] = v
            end
        end
    end
end

-- ============================================================
-- SAUVEGARDE DES ÉTATS PAR COMPTE
-- ============================================================
local function buildAccountSaveData()
    return {
        settings = serializeSettings(),
        savedAt  = os.time and os.time() or 0,
        version  = 2,
    }
end

local function applySaveData(data)
    if not data then return end
    if data.settings then
        deserializeSettings(data.settings)
    end
end

