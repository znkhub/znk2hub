-- ============================================================
-- SÉRIALISATION SETTINGS
-- ============================================================
local function serializeSettings()
    local out = {}
    for k, v in pairs(settings) do
        if type(v) == "Color3" then
            out[k] = {_type="Color3", r=v.R, g=v.G, b=v.B}
        elseif type(v) == "EnumItem" then
            out[k] = {_type="EnumItem", val=tostring(v)}
        elseif type(v) == "table" and v.type and v.code then
            -- Keybind personnalisé
            out[k] = {_type="Keybind", kbtype=v.type, code=tostring(v.code)}
        else
            out[k] = v
        end
    end
    return out
end
local function deserializeSettings(data)
    if not data then return end
    for k, v in pairs(data) do
        if type(v) == "table" then
            if v._type == "Color3" then
                settings[k] = Color3.new(v.r or 0, v.g or 0, v.b or 0)
            elseif v._type == "EnumItem" then
                pcall(function()
                    local parts = {}
                    for p in (v.val or ""):gmatch("[^%.]+") do table.insert(parts, p) end
                    if #parts == 3 then settings[k] = Enum[parts[2]][parts[3]] end
                end)
            elseif v._type == "Keybind" then
                pcall(function()
                    if v.kbtype == "key" then
                        local parts = {}
                        for p in (v.code or ""):gmatch("[^%.]+") do table.insert(parts, p) end
                        if #parts == 3 then
                            settings[k] = {type="key", code=Enum[parts[2]][parts[3]]}
                        end
                    elseif v.kbtype == "mouse" then
                        local parts = {}
                        for p in (v.code or ""):gmatch("[^%.]+") do table.insert(parts, p) end
                        if #parts == 3 then
                            settings[k] = {type="mouse", code=Enum[parts[2]][parts[3]]}
                        end
                    end
                end)
            end
        else
            if settings[k] ~= nil and type(settings[k]) ~= "table" then settings[k] = v end
        end
    end
end
local function buildAccountSaveData()
    return { settings = serializeSettings(), savedAt = os.time and os.time() or 0, version = 4 }
end
local function applySaveData(data)
    if not data then return end
    if data.settings then deserializeSettings(data.settings) end
end

_G.ZNK_ApplyAccountSave = function(data)
    applySaveData(data)
    if _G.ZNK_RefreshAllToggles then _G.ZNK_RefreshAllToggles() end
end

local function saveCurrentAccount()
