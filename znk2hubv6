local function createKeybindButton(parent, xPos, yPos, w, h, currentKB, labelPrefix, onChanged)
    local isListening = false

    local BtnBG = Instance.new("Frame", parent)
    BtnBG.Size = UDim2.new(0, w, 0, h)
    BtnBG.Position = UDim2.new(0, xPos, 0, yPos)
    BtnBG.BackgroundColor3 = Color3.fromRGB(20, 16, 28)
    BtnBG.BorderSizePixel = 0
    Instance.new("UICorner", BtnBG).CornerRadius = UDim.new(0, 6)
    local BtnStroke = Instance.new("UIStroke", BtnBG)
    BtnStroke.Color = Color3.fromRGB(80, 60, 100); BtnStroke.Thickness = 1.5

    local BtnLabel = Instance.new("TextButton", BtnBG)
    BtnLabel.Size = UDim2.new(1, 0, 1, 0)
    BtnLabel.BackgroundTransparency = 1
    BtnLabel.Font = Enum.Font.GothamBold; BtnLabel.TextSize = 11
    BtnLabel.TextColor3 = Color3.fromRGB(200, 195, 215)
    BtnLabel.AutoButtonColor = false
    BtnLabel.Text = keybindToString(currentKB)

    local function setListening(v)
        isListening = v
        if v then
            BtnLabel.Text = "[ Appuie une touche... ]"
            BtnStroke.Color = Color3.fromRGB(185, 45, 255)
            BtnStroke.Thickness = 2
        else
            BtnLabel.Text = keybindToString(currentKB)
            BtnStroke.Color = Color3.fromRGB(80, 60, 100)
            BtnStroke.Thickness = 1.5
        end
    end

    BtnLabel.MouseButton1Click:Connect(function()
        if isListening then setListening(false); return end
        setListening(true)
    end)

    -- Écoute globale
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if not isListening then return end
        -- Clavier
        if input.KeyCode ~= Enum.KeyCode.Unknown and input.UserInputType == Enum.UserInputType.Keyboard then
            currentKB = {type="key", code=input.KeyCode}
            onChanged(currentKB)
            setListening(false)
            return
        end
        -- Souris
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.MouseButton2
        or input.UserInputType == Enum.UserInputType.MouseButton3 then
            currentKB = {type="mouse", code=input.UserInputType}
            onChanged(currentKB)
            setListening(false)
            return
        end
    end)

    return BtnBG, BtnLabel
end

