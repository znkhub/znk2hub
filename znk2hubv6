local function isVisible(targetPart)
    local origin = Camera.CFrame.Position
    local direction = (targetPart.Position - origin)
    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    rayParams.FilterDescendantsInstances = {LocalPlayer.Character}
    local result = Workspace:Raycast(origin, direction, rayParams)
    if result then return result.Instance:IsDescendantOf(targetPart.Parent) end
    return true
end

local function getClosestPlayer(fov, targetPart, teamCheck, visCheck)
    local closest = nil
    local closestDist = fov
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if teamCheck and player.Team == LocalPlayer.Team then continue end
        local char = player.Character
        if not char then continue end
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if not humanoid or humanoid.Health <= 0 then continue end
        local part = char:FindFirstChild(targetPart)
        if not part then continue end
        if visCheck then
            local ok, visible = pcall(isVisible, part)
            if not ok or not visible then continue end
        end
        local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
        if not onScreen then continue end
        local dist = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
        if dist < closestDist then closestDist = dist; closest = part end
    end
    return closest
end

local lastAimUpdate = 0
local lastClickTime = 0

RunService.RenderStepped:Connect(function()
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    fovCircle.Position = screenCenter
    fovCircle.Radius = settings.aimFov
    fovCircle.Color = settings.aimFovColor
    fovCircle.Visible = settings.aimEnabled and settings.aimShowFov

    silentFovCircle.Position = screenCenter
    silentFovCircle.Radius = settings.silentFov
    silentFovCircle.Color = settings.silentFovColor
    silentFovCircle.Visible = settings.silentEnabled and settings.silentShowFov

    -- ★ Aim Assist: utilise le keybind personnalisé ★
    if settings.aimEnabled then
        local holdActive = isKeybindPressed(settings.aimHoldKeybind)
        if holdActive then
            local currentTime = tick()
            if currentTime - lastAimUpdate >= 0.016 then
                lastAimUpdate = currentTime
                local target = getClosestPlayer(settings.aimFov, settings.aimTargetPart, settings.aimTeamCheck, settings.aimVisCheck)
                if target then
                    if mousemoverel then
                        local targetPos = Camera:WorldToViewportPoint(target.Position)
                        local delta = (Vector2.new(targetPos.X, targetPos.Y) - screenCenter) / settings.aimSmoothness
                        mousemoverel(delta.X, delta.Y)
                    else
                        local currentCF = Camera.CFrame
                        local lookAt = CFrame.lookAt(currentCF.Position, target.Position)
                        Camera.CFrame = currentCF:Lerp(lookAt, 0.05 / settings.aimSmoothness)
                    end
                end
            end
        end
    end

    if settings.rageEnabled then
        local target = getClosestPlayer(settings.aimFov, settings.aimTargetPart, settings.aimTeamCheck, false)
        if target then
            if settings.rageAutoShoot then
                if not UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
                    pcall(mouse1click)
                end
            end
            if settings.rageRapidFire then
                local currentTime = tick()
                if currentTime - lastClickTime >= (settings.rageRapidDelay / 1000) then
                    pcall(mouse1click)
                    lastClickTime = currentTime
                end
            end
        end
    end
end)

