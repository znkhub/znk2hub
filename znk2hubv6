-- VISUALS LOOP
-- ============================================================
RunService.RenderStepped:Connect(function()
    -- Fullbright
    if settings.fullbright then
        LightingESP.Brightness = 10
        LightingESP.ClockTime = 14
    end
    -- Speed
    if settings.speedEnabled and LocalPlayer.Character then
        local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum.WalkSpeed = 16 * settings.speedValue end
    end
    -- Jump
    if settings.jumpEnabled and LocalPlayer.Character then
        local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum.JumpPower = settings.jumpValue end
    end
    -- Bloom
    local bloom = LightingESP:FindFirstChildOfClass("BloomEffect") or Instance.new("BloomEffect", LightingESP)
    bloom.Enabled = settings.bloomEnabled
    if settings.bloomEnabled then
        bloom.Intensity = settings.bloomIntensity
        bloom.Size = settings.bloomSize
    end
    -- FPS Boost
    if settings.fpsBoost then
        settings.bloomEnabled = false
        pcall(function() LightingESP.GlobalShadows = false end)
    end
    -- Anti-AFK
    if settings.antiAFK then
        pcall(function()
            local vjs = LocalPlayer:FindFirstChild("PlayerScripts") and LocalPlayer.PlayerScripts:FindFirstChild("RbxCharacterSounds")
            if vjs then vjs:Destroy() end
        end)
    end
    -- Update timer display
    updateRemainingTimeDisplay()
    TBUser.Text = "👤 "..loggedUsername.." | ⏱ "..currentKeyRemaining
end)

