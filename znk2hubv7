-- Retourne le chemin complet du fichier bureau si trouvé, sinon nil
local function findDesktopSaveFile()
    -- Essai 1 : executor supporte getspecialfolders / getfolder
    if getspecialfolders then
        local ok, folders = pcall(getspecialfolders)
        if ok and folders and folders.Desktop then
            local path = folders.Desktop .. "\\" .. DESKTOP_SAVE_MAGIC_NAME
            return path
        end
    end
    -- Essai 2 : readfile direct avec chemins communs
    for _, prefix in ipairs(DESKTOP_PATHS) do
        local path = prefix .. DESKTOP_SAVE_MAGIC_NAME
        if isfile and isfile(path) then
            return path
        end
    end
    -- Essai 3 : dossier workspace (fallback)
    local fallback = DESKTOP_SAVE_MAGIC_NAME
    return fallback
end

-- Vérifie si le fichier magique bureau existe
local function desktopFileExists()
    -- Tente de trouver ou créer le fichier
    if getspecialfolders then
        local ok, folders = pcall(getspecialfolders)
        if ok and folders and folders.Desktop then
            local path = folders.Desktop .. "\\" .. DESKTOP_SAVE_MAGIC_NAME
            if isfile and isfile(path) then return true, path end
            return false, path
        end
    end
    for _, prefix in ipairs(DESKTOP_PATHS) do
        local path = prefix .. DESKTOP_SAVE_MAGIC_NAME
        if isfile and isfile(path) then return true, path end
    end
    -- Dernier recours: même dossier que le script
    if isfile and isfile(DESKTOP_SAVE_MAGIC_NAME) then
        return true, DESKTOP_SAVE_MAGIC_NAME
    end
    return false, DESKTOP_SAVE_MAGIC_NAME
end

local function loadDesktopSave()
    local exists, path = desktopFileExists()
    if not exists then return nil end
    local raw = safeRead(path)
    if not raw then return nil end
    local ok, data = pcall(HttpService.JSONDecode, HttpService, raw)
    if ok and data and data._znk_magic == "ZNK_HUB_SAVE_V7" then
        return data
    end
    return nil
end

local function saveDesktopSave(saveData)
    local exists, path = desktopFileExists()
    if not exists then
        -- Informe que le fichier n'existe pas → sauvegarde bureau impossible
        return false
    end
    saveData._znk_magic = "ZNK_HUB_SAVE_V7"
    saveData._savedAt = os.time and os.time() or 0
    local ok, encoded = pcall(HttpService.JSONEncode, HttpService, saveData)
    if ok then
        safeWrite(path, encoded)
        return true
    end
    return false
end

