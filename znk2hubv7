local function makeSlider(parent, label, settingKey, minV, maxV, step)
    local row = Instance.new("Frame", parent)
    row.Size = UDim2.new(1, 0, 0, 50); row.BackgroundColor3 = panelSoft; row.BorderSizePixel = 0
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)
    local lbl = Instance.new("TextLabel", row)
    lbl.Size = UDim2.new(1, -60, 0, 22); lbl.Position = UDim2.new(0, 10, 0, 4)
    lbl.BackgroundTransparency = 1; lbl.Text = label
    lbl.Font = Enum.Font.GothamBold; lbl.TextSize = 12; lbl.TextColor3 = Color3.fromRGB(230, 225, 245)
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    local valLbl = Instance.new("TextLabel", row)
    valLbl.Size = UDim2.new(0, 50, 0, 22); valLbl.Position = UDim2.new(1, -58, 0, 4)
    valLbl.BackgroundTransparency = 1; valLbl.Text = tostring(settings[settingKey])
    valLbl.Font = Enum.Font.GothamBold; valLbl.TextSize = 11; valLbl.TextColor3 = currentTheme
    valLbl.TextXAlignment = Enum.TextXAlignment.Right
    local trackBG = Instance.new("Frame", row)
    trackBG.Size = UDim2.new(1, -20, 0, 6); trackBG.Position = UDim2.new(0, 10, 0, 34)
    trackBG.BackgroundColor3 = Color3.fromRGB(40, 36, 55); trackBG.BorderSizePixel = 0
    Instance.new("UICorner", trackBG).CornerRadius = UDim.new(1, 0)
    local fill = Instance.new("Frame", trackBG)
    fill.Size = UDim2.new((settings[settingKey] - minV) / (maxV - minV), 0, 1, 0)
    fill.BackgroundColor3 = currentTheme; fill.BorderSizePixel = 0
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
    local handle = Instance.new("TextButton", trackBG)
    handle.Size = UDim2.new(0, 14, 0, 14)
    handle.Position = UDim2.new((settings[settingKey] - minV) / (maxV - minV), -7, 0.5, -7)
    handle.BackgroundColor3 = Color3.fromRGB(255, 255, 255); handle.Text = ""; handle.AutoButtonColor = false
    handle.BorderSizePixel = 0; handle.ZIndex = 2
    Instance.new("UICorner", handle).CornerRadius = UDim.new(1, 0)

    local dragging = false
    handle.MouseButton1Down:Connect(function() dragging = true end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
    RunService.RenderStepped:Connect(function()
        if not dragging then return end
        local mouseX = UserInputService:GetMouseLocation().X
        local trackPos = trackBG.AbsolutePosition.X
        local trackWidth = trackBG.AbsoluteSize.X
        local ratio = math.clamp((mouseX - trackPos) / trackWidth, 0, 1)
        local raw = minV + ratio * (maxV - minV)
        local val = step and (math.round(raw / step) * step) or math.round(raw)
        settings[settingKey] = val
        fill.Size = UDim2.new(ratio, 0, 1, 0)
        handle.Position = UDim2.new(ratio, -7, 0.5, -7)
        valLbl.Text = tostring(val)
    end)
    return row
end

-- ★ MODIF 2: Bouton keybind générique (pour aim toggle ET minimize)
local listeningForKeybind = false
local function makeKeybindBtn(parent, label, settingKey, onChanged)
    local row = Instance.new("Frame", parent)
    row.Size = UDim2.new(1, 0, 0, 40); row.BackgroundColor3 = panelSoft; row.BorderSizePixel = 0
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)
    local lbl = Instance.new("TextLabel", row)
    lbl.Size = UDim2.new(0.55, 0, 1, 0); lbl.Position = UDim2.new(0, 10, 0, 0)
    lbl.BackgroundTransparency = 1; lbl.Text = label
    lbl.Font = Enum.Font.GothamBold; lbl.TextSize = 12; lbl.TextColor3 = Color3.fromRGB(230, 225, 245)
    lbl.TextXAlignment = Enum.TextXAlignment.Left

    local kbBtn = Instance.new("TextButton", row)
    kbBtn.Size = UDim2.new(0, 110, 0, 26); kbBtn.Position = UDim2.new(1, -118, 0.5, -13)
    kbBtn.BackgroundColor3 = Color3.fromRGB(35, 20, 60); kbBtn.BorderSizePixel = 0
    kbBtn.Text = keybindToString(settings[settingKey])
    kbBtn.Font = Enum.Font.GothamBold; kbBtn.TextSize = 11
    kbBtn.TextColor3 = currentTheme; kbBtn.AutoButtonColor = false
    Instance.new("UICorner", kbBtn).CornerRadius = UDim.new(0, 6)
    Instance.new("UIStroke", kbBtn).Color = currentTheme

    local listening = false
    kbBtn.MouseButton1Click:Connect(function()
        if listeningForKeybind and not listening then return end
        listening = true; listeningForKeybind = true
        kbBtn.Text = "[ appuie... ]"
        kbBtn.TextColor3 = Color3.fromRGB(255, 200, 50)
        kbBtn.BackgroundColor3 = Color3.fromRGB(50, 30, 80)
        local conn1, conn2
        conn1 = UserInputService.InputBegan:Connect(function(input, gp)
            if gp then return end
            local newKb = nil
            if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode ~= Enum.KeyCode.Escape then
                newKb = {type="key", code=input.KeyCode}
            elseif input.UserInputType == Enum.UserInputType.MouseButton1 or
                   input.UserInputType == Enum.UserInputType.MouseButton2 or
                   input.UserInputType == Enum.UserInputType.MouseButton3 then
                newKb = {type="mouse", code=input.UserInputType}
            end
            if newKb then
                settings[settingKey] = newKb
                kbBtn.Text = keybindToString(newKb)
                kbBtn.TextColor3 = currentTheme
                kbBtn.BackgroundColor3 = Color3.fromRGB(35, 20, 60)
                if onChanged then onChanged(newKb) end
            else
                -- ESC = annuler
                kbBtn.Text = keybindToString(settings[settingKey])
                kbBtn.TextColor3 = currentTheme
                kbBtn.BackgroundColor3 = Color3.fromRGB(35, 20, 60)
            end
            listening = false; listeningForKeybind = false
            if conn1 then conn1:Disconnect() end
            if conn2 then conn2:Disconnect() end
        end)
    end)
    return row
end

