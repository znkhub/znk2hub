-- ============================================================
-- TEMPS
-- ============================================================
local function formatTime(seconds)
    if not seconds or seconds <= 0 then return "Expirée" end
    local days  = math.floor(seconds / 86400)
    local hours = math.floor((seconds % 86400) / 3600)
    local mins  = math.floor((seconds % 3600) / 60)
    local secs  = seconds % 60
    if days  > 0 then return days.."j "..hours.."h" end
    if hours > 0 then return hours.."h "..mins.."m" end
    if mins  > 0 then return mins.."m "..secs.."s" end
    return secs.."s"
end
local function getAccountKeyRemaining(accountData)
    if not accountData then return "Aucune key" end
    local duration    = tonumber(accountData.keyDuration)
    local activatedAt = tonumber(accountData.keyActivatedAt) or 0
    if not duration or duration >= 999999999 then return "Illimitée" end
    local now = os.time and os.time() or 0
    return formatTime(math.max((activatedAt + duration) - now, 0))
end
local function isKeyExpiredForAccount(accountData)
    if not accountData then return true end
    local duration    = tonumber(accountData.keyDuration)
    local activatedAt = tonumber(accountData.keyActivatedAt) or 0
    if not duration or duration >= 999999999 then return false end
    return (os.time and os.time() or 0) >= (activatedAt + duration)
end
local function updateRemainingTimeDisplay()
    if currentSessionData then
        currentKeyRemaining = getAccountKeyRemaining(currentSessionData)
    end
end

-- ============================================================
-- KEYS
-- ============================================================
local function isKeyValid(key)
    if not key or key == "" then return false end
    for _, k in pairs(VALID_KEYS) do if key == k then return true end end
    local customKeys = loadCustomKeys()
    for _, entry in pairs(customKeys) do
        if type(entry) == "string" then
            if key == entry then return true end
        elseif type(entry) == "table" and entry.key == key then
            local duration  = tonumber(entry.duration)
            local createdAt = tonumber(entry.createdAt) or 0
            if not duration or duration >= 999999999 then return true end
            if (os.time and os.time() or 0) <= (createdAt + duration) then return true end
        end
    end
    return false
end
local function getCustomKeyMeta(targetKey)
    for _, entry in pairs(loadCustomKeys()) do
        if type(entry) == "table" and entry.key == targetKey then return entry end
        if type(entry) == "string" and entry == targetKey then return {key=entry,duration=999999999,createdAt=0} end
    end
    return nil
end

