local function isKeybindPressed(kb)
    if not kb then return false end
    if kb.type == "key" then
        return UserInputService:IsKeyDown(kb.code)
    elseif kb.type == "mouse" then
        return UserInputService:IsMouseButtonPressed(kb.code)
    end
    return false
end

local function keybindToString(kb)
    if not kb then return "Aucune" end
    if kb.type == "key" then
        local name = tostring(kb.code):gsub("Enum%.KeyCode%.", "")
        return name
    elseif kb.type == "mouse" then
        local name = tostring(kb.code):gsub("Enum%.UserInputType%.", "")
        if name == "MouseButton1" then return "Clic G"
        elseif name == "MouseButton2" then return "Clic D"
        elseif name == "MouseButton3" then return "Molette" end
        return name
    end
    return "?"
end

