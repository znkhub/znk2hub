-- COMPTES
-- ============================================================
local function checkAccount(username, password)
    local accounts = loadAccounts()
    local user = username:lower()
    if accounts[user] and accounts[user].password == password then
        return true, accounts[user]
    end
    return false, nil
end
local function saveAccount(username, password, keyUsed)
    local accounts = loadAccounts()
    local lower = username:lower()
    local now   = os.time and os.time() or 0
    local meta  = getCustomKeyMeta(keyUsed)
    accounts[lower] = {
        password       = password,
        keyUsed        = keyUsed or "",
        createdAt      = accounts[lower] and accounts[lower].createdAt or now,
        keyActivatedAt = now,
        keyDuration    = meta and meta.duration or 999999999,
    }
    saveAccounts(accounts)
    return accounts[lower]
end
local function accountExists(username)
    return loadAccounts()[username:lower()] ~= nil
end

