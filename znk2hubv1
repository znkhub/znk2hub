-- ============================================================
-- UTILITAIRES FICHIER
-- ============================================================
local function safeRead(file)
    if isfile and isfile(file) then
        local ok, v = pcall(readfile, file)
        return ok and v or nil
    end
    return nil
end
local function safeWrite(file, data) pcall(writefile, file, data) end
local function safeDelete(file)
    pcall(function()
        if isfile and isfile(file) then delfile(file) end
    end)
end
local function loadJSON(file)
    local raw = safeRead(file)
    if not raw then return {} end
    local ok, data = pcall(HttpService.JSONDecode, HttpService, raw)
    return (ok and data) or {}
end
local function saveJSON(file, data)
    local ok, encoded = pcall(HttpService.JSONEncode, HttpService, data)
    if ok then safeWrite(file, encoded) end
end
local function loadAccounts()   return loadJSON(ACCOUNTS_FILE) end
local function saveAccounts(a)  saveJSON(ACCOUNTS_FILE, a) end
local function loadCustomKeys() return loadJSON(CUSTOM_KEYS_FILE) end
local function saveCustomKeys(k) saveJSON(CUSTOM_KEYS_FILE, k) end
local function loadSession()    return loadJSON(SESSION_FILE) end
local function saveSession(s)   saveJSON(SESSION_FILE, s) end
local function deleteSession()  safeDelete(SESSION_FILE) end
local function loadWhitelist()  return loadJSON(WHITELIST_FILE) end
local function saveWhitelist(w) saveJSON(WHITELIST_FILE, w) end

