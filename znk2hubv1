local function saveSettings()
    pcall(function()
        local toSave = {}
        for k, v in pairs(settings) do
            if type(v) == "Color3" then toSave[k] = {r=v.R, g=v.G, b=v.B}
            elseif type(v) == "EnumItem" then toSave[k] = tostring(v)
            else toSave[k] = v end
        end
        writefile(SETTINGS_FILE, HttpService:JSONEncode(toSave))
    end)
end

local function loadSettings()
    if not (isfile and isfile(SETTINGS_FILE)) then return end
    local ok, data = pcall(function() return HttpService:JSONDecode(readfile(SETTINGS_FILE)) end)
    if ok and data then
        for k, v in pairs(data) do
            if type(v) == "table" and v.r ~= nil then settings[k] = Color3.new(v.r, v.g, v.b)
            elseif type(v) == "string" and v:find("Enum.KeyCode") then
                pcall(function() settings[k] = Enum.KeyCode[v:match("Enum%.KeyCode%.(.+)")] end)
            else settings[k] = v end
        end
    end
end

