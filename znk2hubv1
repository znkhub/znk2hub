        Dot.BackgroundColor3 = col; Dot.Text = ""; Dot.AutoButtonColor = false; Dot.BorderSizePixel = 0
        Instance.new("UICorner", Dot).CornerRadius = UDim.new(0, 3)
        Instance.new("UIStroke", Dot).Color = Color3.fromRGB(80, 100, 160)
        Dot.MouseButton1Click:Connect(function() Preview.BackgroundColor3 = col; callback(col); saveSettings() end)
    end
    local barDragging = false
    local function pickColorFromBar(inputX)
        local relX = math.clamp((inputX - BarBG.AbsolutePosition.X) / BarBG.AbsoluteSize.X, 0, 1)
        local picked = Color3.fromHSV(relX, 1, 1)
        Cursor.Position = UDim2.new(relX, -2, 0, -2); Preview.BackgroundColor3 = picked; callback(picked); saveSettings()
    end
    BarBG.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then barDragging = true; pickColorFromBar(inp.Position.X) end
    end)
    BarBG.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then barDragging = false end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if barDragging and inp.UserInputType == Enum.UserInputType.MouseMovement then pickColorFromBar(inp.Position.X) end
    end)
    return Container
end

