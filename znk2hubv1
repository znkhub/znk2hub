    Cursor.Size = UDim2.new(0, 4, 1, 4); Cursor.Position = UDim2.new(0, 0, 0, -2)
    Cursor.BackgroundColor3 = Color3.fromRGB(255,255,255); Cursor.BorderSizePixel = 0
