UserInputService.InputBegan:Connect(function(inp, gp)
    if gp then return end
    -- Minimize
    if settings.minimizeKeyCode and inp.KeyCode == settings.minimizeKeyCode then
        toggleMinimize(); return
    end
    -- Others keybinds
    local kc = inp.KeyCode
    if settings.bindESP and kc == settings.bindESPKey then
        settings.redESP = not settings.redESP
        if not settings.redESP then for _, h in pairs(highlights) do h:Destroy() end; highlights = {} end
        notify("ZNK", "ESP "..(settings.redESP and "ON" or "OFF"), 1)
    end
    if settings.bindAimbot and kc == settings.bindAimbotKey then
        settings.aimbot = not settings.aimbot
        if not settings.aimbot then lockedTarget = nil end
        notify("ZNK", "Aimbot "..(settings.aimbot and "ON" or "OFF"), 1)
    end
    if settings.bindSpeed and kc == settings.bindSpeedKey then
        settings.speedEnabled = not settings.speedEnabled
        if humanoid then humanoid.WalkSpeed = settings.speedEnabled and settings.walkSpeed or originalValues.walkSpeed end
        notify("ZNK", "Speed "..(settings.speedEnabled and "ON" or "OFF"), 1)
    end
    if settings.bindFly and kc == settings.bindFlyKey then
        settings.fly = not settings.fly
        notify("ZNK", "Fly "..(settings.fly and "ON" or "OFF"), 1)
    end
    if settings.bindNoclip and kc == settings.bindNoclipKey then
        settings.noclip = not settings.noclip
        notify("ZNK", "Noclip "..(settings.noclip and "ON" or "OFF"), 1)
    end
    if settings.bindInfJump and kc == settings.bindInfJumpKey then
        settings.infiniteJump = not settings.infiniteJump
        notify("ZNK", "Inf. Jump "..(settings.infiniteJump and "ON" or "OFF"), 1)
    end
    if settings.bindSpinbot and kc == settings.bindSpinbotKey then
        settings.spinbot = not settings.spinbot
        notify("ZNK", "SpinBot "..(settings.spinbot and "ON" or "OFF"), 1)
    end
    if settings.bindFullbright and kc == settings.bindFullbrightKey then
        settings.fullbright = not settings.fullbright
        notify("ZNK", "FullBright "..(settings.fullbright and "ON" or "OFF"), 1)
    end
    if settings.bindNoFog and kc == settings.bindNoFogKey then
        settings.noFog = not settings.noFog
        notify("ZNK", "No Fog "..(settings.noFog and "ON" or "OFF"), 1)
    end
    if settings.bindThirdPerson and kc == settings.bindThirdPersonKey then
        settings.thirdPerson = not settings.thirdPerson
        camera.CameraType = settings.thirdPerson and Enum.CameraType.Follow or Enum.CameraType.Custom
        notify("ZNK", "Third Person "..(settings.thirdPerson and "ON" or "OFF"), 1)
