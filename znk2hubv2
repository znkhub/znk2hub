    if settings.bindAntiAFK and kc == settings.bindAntiAFKKey then
        settings.antiAFK = not settings.antiAFK
        notify("ZNK", "Anti-AFK "..(settings.antiAFK and "ON" or "OFF"), 1)
    end
end)

