    local Btn = Instance.new("TextButton", Toggle)
    Btn.Size = UDim2.new(0, 44, 0, 22); Btn.Position = UDim2.new(1, -52, 0.5, -11)
    Btn.BackgroundColor3 = default and currentTheme or Color3.fromRGB(45, 45, 55)
    Btn.Text = ""; Btn.AutoButtonColor = false
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(1, 0)
    local Circle = Instance.new("Frame", Btn)
    Circle.Size = UDim2.new(0, 17, 0, 17)
    Circle.Position = default and UDim2.new(1, -19, 0.5, -8.5) or UDim2.new(0, 2, 0.5, -8.5)
    Circle.BackgroundColor3 = Color3.fromRGB(255, 255, 255); Circle.BorderSizePixel = 0
    Instance.new("UICorner", Circle).CornerRadius = UDim.new(1, 0)
    local enabled = default
    local record = {enabled=enabled, button=Btn, circle=Circle, label=Label, callback=callback}
    toggleRegistry[#toggleRegistry+1] = record
    local function setToggle(val)
        enabled = val; record.enabled = val
        TweenService:Create(Btn, TweenInfo.new(0.2), {
            BackgroundColor3 = val and currentTheme or Color3.fromRGB(45, 45, 55)
        }):Play()
        TweenService:Create(Circle, TweenInfo.new(0.2), {
            Position = val and UDim2.new(1, -19, 0.5, -8.5) or UDim2.new(0, 2, 0.5, -8.5)
        }):Play()
    end
    Btn.MouseButton1Click:Connect(function()
        setToggle(not enabled)
        if callback then callback(enabled) end; saveSettings()
    end)
    record.setToggle = setToggle
    return Toggle, record
end

local function createSlider(tabName, textKey, min, max, default, suffix, callback)
    local S = Instance.new("Frame", Content)
    S.Size = UDim2.new(1, 0, 0, 58); S.BackgroundColor3 = panelSoft
    S.BorderSizePixel = 0; S.Visible = (tabName == currentTab)
