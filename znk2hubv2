-- ESP Loop
local espUpdateConn = RunService.Heartbeat:Connect(function()
    if not (settings.redESP or settings.rainbowESP) then
        for _, h in pairs(highlights) do h:Destroy() end; highlights = {}; return
    end
    rainbowHue = (rainbowHue + 0.005) % 1
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            if not highlights[plr.Name] then
                local h = Instance.new("SelectionBox")
                h.SurfaceTransparency = settings.espTransparency
                h.LineThickness = 0.06
                h.Adornee = plr.Character
                h.Parent = Workspace
                highlights[plr.Name] = h
            end
            local h = highlights[plr.Name]
            if settings.rainbowESP then
                h.Color3 = Color3.fromHSV(rainbowHue, 1, 1)
            else
                h.Color3 = settings.espColor
            end
        end
    end
    -- Nettoyer les joueurs partis
    for name, h in pairs(highlights) do
        if not Players:FindFirstChild(name) then h:Destroy(); highlights[name] = nil end
    end
end)
connections[#connections+1] = espUpdateConn

-- Aimbot Loop
local aimbotConn = RunService.RenderStepped:Connect(function()
    if not settings.aimbot then return end
    local lockActive = isAimbotLockPressed()
    if settings.aimbotLock and not lockActive then lockedTarget = nil; return end

    local bestTarget = nil; local bestDist = settings.aimbotFOV
    local screenCenter = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            local part = plr.Character:FindFirstChild(settings.targetPart)
            if part then
                local sp, onScreen = camera:WorldToScreenPoint(part.Position)
                if onScreen then
                    local dist = (Vector2.new(sp.X, sp.Y) - screenCenter).Magnitude
                    if dist < bestDist then bestDist = dist; bestTarget = part end
                end
            end
        end
    end
    if bestTarget then
        if settings.aimbotLock then lockedTarget = bestTarget end
        local targetPos = lockedTarget and lockedTarget.Position or bestTarget.Position
        local newCF = CFrame.new(camera.CFrame.Position, targetPos)
        camera.CFrame = camera.CFrame:Lerp(newCF, 1/settings.aimbotSmooth)
    end
end)
connections[#connections+1] = aimbotConn

