local function toggleMinimize()
    isMinimized = not isMinimized
    if isMinimized then
        saveStates()
        TweenService:Create(Main, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
            Size = UDim2.new(0, 0, 0, 0), Position = UDim2.new(0.5, 0, 0.5, 0)
        }):Play()
        task.delay(0.3, function() Main.Visible = false; LogoButton.Visible = true end)
    else
        Main.Visible = true; LogoButton.Visible = false
        Main.Size = UDim2.new(0, 0, 0, 0); Main.Position = UDim2.new(0.5, 0, 0.5, 0)
        TweenService:Create(Main, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, MAIN_W, 0, MAIN_H),
            Position = UDim2.new(0.5, -MAIN_W/2, 0.5, -MAIN_H/2)
        }):Play()
    end
end
