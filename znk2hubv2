-- ============================================================
-- DÉTECTION TOUCHE AIMBOT LOCK
-- ============================================================
local function isAimbotLockPressed()
    if settings.aimbotLockIsMouseButton then
        local btn = settings.aimbotLockMouseButtonNum
        if btn == 2 then
            return UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
        elseif btn == 3 then
            return UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton3)
        elseif btn == 4 or btn == 5 then
            -- boutons latéraux souris: utilisation de GetMouseButtonsPressed (si disponible)
            -- fallback: détection via InputBegan/InputEnded
            return isAimbotLockHeld
        end
    elseif settings.aimbotLockKeyCode then
        return UserInputService:IsKeyDown(settings.aimbotLockKeyCode)
    end
    return false
end

-- Connexion pour boutons latéraux souris (4/5)
UserInputService.InputBegan:Connect(function(inp)
    if settings.aimbotLock and settings.aimbotLockIsMouseButton then
        local btn = settings.aimbotLockMouseButtonNum
        if btn == 4 or btn == 5 then
            -- Les boutons 4/5 apparaissent souvent comme MouseButton3 ou des touches spéciales
            -- On les détecte par KeyCode si possible
            if inp.UserInputType == Enum.UserInputType.MouseButton3 and btn == 3 then
                isAimbotLockHeld = true
            end
        end
    end
end)
UserInputService.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton3 then
        isAimbotLockHeld = false
    end
end)

