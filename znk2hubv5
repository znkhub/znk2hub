        pTitle.TextColor3 = Color3.fromRGB(220,215,235)

        -- RGB sliders
        local function makeRGBSlider(parent, channel, yPos, defVal)
            local bg = Instance.new("Frame", parent)
            bg.Size = UDim2.new(1,-20,0,5); bg.Position = UDim2.new(0,10,0,yPos)
