local function makeSlider(parent, label, settingKey, min, max, round, callback)
    local Row = Instance.new("Frame", parent)
    Row.Size = UDim2.new(1,0,0,52); Row.BackgroundColor3 = panelSoft; Row.BorderSizePixel = 0
    Instance.new("UICorner", Row).CornerRadius = UDim.new(0,8)

    local Lbl = Instance.new("TextLabel", Row)
    Lbl.Size = UDim2.new(1,-60,0,22); Lbl.Position = UDim2.new(0,10,0,4)
    Lbl.BackgroundTransparency = 1; Lbl.Text = label
    Lbl.Font = Enum.Font.GothamBold; Lbl.TextSize = 12; Lbl.TextColor3 = Color3.fromRGB(220,215,235)
    Lbl.TextXAlignment = Enum.TextXAlignment.Left

    local ValLbl = Instance.new("TextLabel", Row)
    ValLbl.Size = UDim2.new(0,55,0,22); ValLbl.Position = UDim2.new(1,-60,0,4)
    ValLbl.BackgroundTransparency = 1
    local val = settings[settingKey]
    ValLbl.Text = round and tostring(math.floor(val)) or tostring(math.floor(val*100)/100)
    ValLbl.Font = Enum.Font.GothamBold; ValLbl.TextSize = 12; ValLbl.TextColor3 = currentTheme
    ValLbl.TextXAlignment = Enum.TextXAlignment.Right

    local TrackBG = Instance.new("Frame", Row)
    TrackBG.Size = UDim2.new(1,-20,0,6); TrackBG.Position = UDim2.new(0,10,0,34)
    TrackBG.BackgroundColor3 = Color3.fromRGB(40,38,50); TrackBG.BorderSizePixel = 0
    Instance.new("UICorner", TrackBG).CornerRadius = UDim.new(1,0)

    local TrackFill = Instance.new("Frame", TrackBG)
    local pct = (val - min) / (max - min)
    TrackFill.Size = UDim2.new(pct,0,1,0); TrackFill.BackgroundColor3 = currentTheme; TrackFill.BorderSizePixel = 0
    Instance.new("UICorner", TrackFill).CornerRadius = UDim.new(1,0)

    local Knob2 = Instance.new("Frame", TrackBG)
    Knob2.Size = UDim2.new(0,14,0,14); Knob2.Position = UDim2.new(pct,0,0.5,-7)
    Knob2.AnchorPoint = Vector2.new(0.5,0.5)
    Knob2.BackgroundColor3 = Color3.fromRGB(255,255,255); Knob2.BorderSizePixel = 0
    Instance.new("UICorner", Knob2).CornerRadius = UDim.new(1,0)

    local dragging = false
    local SliderBtn = Instance.new("TextButton", TrackBG)
    SliderBtn.Size = UDim2.new(1,0,0,20); SliderBtn.Position = UDim2.new(0,0,0.5,-10)
    SliderBtn.BackgroundTransparency = 1; SliderBtn.Text = ""

    local function updateSlider(inputX)
        local relX = math.clamp((inputX - TrackBG.AbsolutePosition.X) / TrackBG.AbsoluteSize.X, 0, 1)
        local newVal = min + relX * (max - min)
        if round then newVal = math.floor(newVal + 0.5) end
        newVal = math.clamp(newVal, min, max)
        settings[settingKey] = newVal
        TrackFill.Size = UDim2.new(relX, 0, 1, 0)
        Knob2.Position = UDim2.new(relX, 0, 0.5, -7)
        ValLbl.Text = round and tostring(math.floor(newVal)) or tostring(math.floor(newVal*100)/100)
        if callback then callback(newVal) end
    end

    SliderBtn.MouseButton1Down:Connect(function() dragging = true end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            updateSlider(i.Position.X)
        end
    end)
    SliderBtn.MouseButton1Down:Connect(function(x,y)
        updateSlider(x)
    end)
    return Row
end

