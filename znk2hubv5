            Healthbar.Visible=false; BehindHealth.Visible=false; HealthText.Visible=false
            WeaponIcon.Visible=false; LeftTop.Visible=false; LeftSide.Visible=false
            BottomSide.Visible=false; BottomDown.Visible=false; RightTop.Visible=false
            RightSide.Visible=false; BottomRightS.Visible=false; BottomRightD.Visible=false
            Chams.Enabled=false
        end

        local Connection
        Connection = ESP_Data.Connections.RunService.RenderStepped:Connect(function()
            if not settings.espEnabled then HideESP(); return end
            if not plr or not plr.Parent then
                HideESP(); Connection:Disconnect(); return
            end
            local char = plr.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                local HRP = char.HumanoidRootPart
                local Humanoid = char:FindFirstChildOfClass("Humanoid")
                if not Humanoid then HideESP(); return end
                local Pos, OnScreen = Cam:WorldToScreenPoint(HRP.Position)
                local Dist = (Cam.CFrame.Position - HRP.Position).Magnitude / 3.5714285714

                if OnScreen and Dist <= settings.espMaxDistance then
                    local isEnemy = settings.espTeamCheck and (plr ~= lplayer) and
                        ((lplayer.Team ~= plr.Team and plr.Team) or (not lplayer.Team and not plr.Team))
                    if not isEnemy then HideESP(); return end

                    local Size = HRP.Size.Y
                    local scaleFactor = (Size * Cam.ViewportSize.Y) / (Pos.Z * 2)
                    local w, h = 3 * scaleFactor, 4.5 * scaleFactor

                    -- Fade out
                    if settings.espFadeOut then
                        for _, el in pairs({Box, Outline, Name, Distance, Weapon, Healthbar, BehindHealth, HealthText, WeaponIcon, LeftTop, LeftSide, BottomSide, BottomDown, RightTop, RightSide, BottomRightS, BottomRightD, Chams}) do
                            pcall(ESPFunctions.FadeOutOnDist, ESPFunctions, el, Dist)
                        end
                    end

                    -- Chams
                    Chams.Adornee = char
                    Chams.Enabled = settings.espChams
                    Chams.FillColor = settings.espChamsColor
                    Chams.OutlineColor = settings.espChamsOutline
                    if settings.espChamsThermal then
                        local breathe = math.atan(math.sin(tick() * 2)) * 2 / math.pi
                        Chams.FillTransparency = math.max(0, math.min(1, breathe * 0.5 + 0.4))
                        Chams.OutlineTransparency = 0
                    else
                        Chams.FillTransparency = 0.5
                        Chams.OutlineTransparency = 0
                    end
                    Chams.DepthMode = "AlwaysOnTop"

                    -- Corner boxes
                    local ce = settings.espBoxesCorner
                    LeftTop.Visible=ce; LeftTop.Position=UDim2.new(0,Pos.X-w/2,0,Pos.Y-h/2); LeftTop.Size=UDim2.new(0,w/5,0,1)
                    LeftSide.Visible=ce; LeftSide.Position=UDim2.new(0,Pos.X-w/2,0,Pos.Y-h/2); LeftSide.Size=UDim2.new(0,1,0,h/5)
                    BottomSide.Visible=ce; BottomSide.Position=UDim2.new(0,Pos.X-w/2,0,Pos.Y+h/2); BottomSide.Size=UDim2.new(0,1,0,h/5); BottomSide.AnchorPoint=Vector2.new(0,5)
                    BottomDown.Visible=ce; BottomDown.Position=UDim2.new(0,Pos.X-w/2,0,Pos.Y+h/2); BottomDown.Size=UDim2.new(0,w/5,0,1); BottomDown.AnchorPoint=Vector2.new(0,1)
                    RightTop.Visible=ce; RightTop.Position=UDim2.new(0,Pos.X+w/2,0,Pos.Y-h/2); RightTop.Size=UDim2.new(0,w/5,0,1); RightTop.AnchorPoint=Vector2.new(1,0)
                    RightSide.Visible=ce; RightSide.Position=UDim2.new(0,Pos.X+w/2-1,0,Pos.Y-h/2); RightSide.Size=UDim2.new(0,1,0,h/5)
                    BottomRightS.Visible=ce; BottomRightS.Position=UDim2.new(0,Pos.X+w/2,0,Pos.Y+h/2); BottomRightS.Size=UDim2.new(0,1,0,h/5); BottomRightS.AnchorPoint=Vector2.new(1,1)
                    BottomRightD.Visible=ce; BottomRightD.Position=UDim2.new(0,Pos.X+w/2,0,Pos.Y+h/2); BottomRightD.Size=UDim2.new(0,w/5,0,1); BottomRightD.AnchorPoint=Vector2.new(1,1)

                    -- Box
                    Box.Position = UDim2.new(0,Pos.X-w/2,0,Pos.Y-h/2)
                    Box.Size = UDim2.new(0,w,0,h)
                    Box.Visible = settings.espBoxesFull
                    if settings.espBoxesFilled then
                        Box.BackgroundTransparency = 0.75
                    else
                        Box.BackgroundTransparency = 1
                    end
                    RotationAngle = RotationAngle + (tick() - Tick) * 300 * math.cos(math.pi / 4 * tick() - math.pi / 2)
                    GradientFill.Rotation = RotationAngle
                    Tick = tick()

                    -- Healthbar
                    local health = Humanoid.Health / Humanoid.MaxHealth
                    Healthbar.Visible = settings.espHealthbar
                    Healthbar.Position = UDim2.new(0, Pos.X-w/2-6, 0, Pos.Y-h/2 + h*(1-health))
                    Healthbar.Size = UDim2.new(0, 2.5, 0, h*health)
                    BehindHealth.Visible = settings.espHealthbar
                    BehindHealth.Position = UDim2.new(0, Pos.X-w/2-6, 0, Pos.Y-h/2)
                    BehindHealth.Size = UDim2.new(0, 2.5, 0, h)
                    if settings.espHealthText and Humanoid.Health < Humanoid.MaxHealth then
                        local hp = math.floor(health * 100)
                        HealthText.Position = UDim2.new(0, Pos.X-w/2-6, 0, Pos.Y-h/2 + h*(1-hp/100) + 3)
                        HealthText.Text = tostring(hp)
                        HealthText.Visible = true
                        HealthText.TextColor3 = settings.espChamsColor
                    else
                        HealthText.Visible = false
                    end

                    -- Names
                    Name.Visible = settings.espNames
                    local isFriend = pcall(function() return lplayer:IsFriendsWith(plr.UserId) end)
                    if settings.espDistance then
                        Name.Text = string.format('(<font color="rgb(255,0,0)">E</font>) %s [%d]', plr.Name, math.floor(Dist))
                    else
