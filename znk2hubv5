            fill.BorderSizePixel=0
            Instance.new("UICorner", fill).CornerRadius = UDim.new(1,0)
            local lbl = Instance.new("TextLabel", parent)
            lbl.Size = UDim2.new(0,20,0,16); lbl.Position = UDim2.new(0,10,0,yPos-18)
            lbl.BackgroundTransparency=1; lbl.Text=channel; lbl.Font=Enum.Font.GothamBold; lbl.TextSize=10
            lbl.TextColor3 = Color3.fromRGB(180,175,195); lbl.TextXAlignment=Enum.TextXAlignment.Left
            local valLbl = Instance.new("TextLabel", parent)
            valLbl.Size = UDim2.new(0,30,0,16); valLbl.Position = UDim2.new(1,-40,0,yPos-18)
            valLbl.BackgroundTransparency=1; valLbl.Text=tostring(defVal); valLbl.Font=Enum.Font.GothamBold; valLbl.TextSize=10
            valLbl.TextColor3 = Color3.fromRGB(180,175,195); valLbl.TextXAlignment=Enum.TextXAlignment.Right
            local sBtn = Instance.new("TextButton", bg)
            sBtn.Size = UDim2.new(1,0,0,18); sBtn.Position = UDim2.new(0,0,0.5,-9)
            sBtn.BackgroundTransparency=1; sBtn.Text=""
            return fill, valLbl, sBtn, defVal
        end

        local curColor = settings[settingKey]
        local rVal, gVal, bVal = math.floor(curColor.R*255), math.floor(curColor.G*255), math.floor(curColor.B*255)

        local rFill, rLbl, rBtn = makeRGBSlider(pFrame, "R", 60, rVal)
        local gFill, gLbl, gBtn = makeRGBSlider(pFrame, "G", 100, gVal)
        local bFill, bLbl, bBtn = makeRGBSlider(pFrame, "B", 140, bVal)

        local previewBox = Instance.new("Frame", pFrame)
        previewBox.Size = UDim2.new(0,60,0,28); previewBox.Position = UDim2.new(0.5,-30,0,156)
        previewBox.BackgroundColor3 = curColor; previewBox.BorderSizePixel=0
        Instance.new("UICorner", previewBox).CornerRadius = UDim.new(0,6)

        local function updateColor()
            local newColor = Color3.fromRGB(rVal, gVal, bVal)
            settings[settingKey] = newColor
            ColorPreview.BackgroundColor3 = newColor
            previewBox.BackgroundColor3 = newColor
            if callback then callback(newColor) end
        end

        local function makeSliderDrag(fill, lbl, btn, getVal, setVal, max)
            local drag = false
            btn.MouseButton1Down:Connect(function() drag = true end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end
            end)
            UserInputService.InputChanged:Connect(function(i)
                if drag and i.UserInputType == Enum.UserInputType.MouseMovement then
                    local bg = fill.Parent
                    local relX = math.clamp((i.Position.X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
                    local v = math.floor(relX * max + 0.5)
                    setVal(v)
                    fill.Size = UDim2.new(relX,0,1,0)
                    lbl.Text = tostring(v)
                    updateColor()
                end
            end)
        end

        makeSliderDrag(rFill, rLbl, rBtn, function() return rVal end, function(v) rVal=v end, 255)
        makeSliderDrag(gFill, gLbl, gBtn, function() return gVal end, function(v) gVal=v end, 255)
        makeSliderDrag(bFill, bLbl, bBtn, function() return bVal end, function(v) bVal=v end, 255)

        local closePickerBtn = Instance.new("TextButton", pFrame)
        closePickerBtn.Size = UDim2.new(1,-20,0,28); closePickerBtn.Position = UDim2.new(0,10,1,-36)
        closePickerBtn.BackgroundColor3 = currentTheme; closePickerBtn.Text = "Appliquer & Fermer"
        closePickerBtn.Font = Enum.Font.GothamBold; closePickerBtn.TextSize = 12
        closePickerBtn.TextColor3 = Color3.fromRGB(255,255,255); closePickerBtn.AutoButtonColor=false
        Instance.new("UICorner", closePickerBtn).CornerRadius = UDim.new(0,6)
        closePickerBtn.MouseButton1Click:Connect(function()
            pickerGui:Destroy()
        end)
    end)
    return Row, ColorPreview
end

