            makeToggle(Content, "Rapid Fire", "rageRapidFire")
            makeSlider(Content, "Délai Rapid Fire (ms)", "rageRapidDelay", 10, 500, true)

        elseif tabName == "Player" then
            makeSection(Content, "Mouvements")
            makeToggle(Content, "Noclip", "noclip")
            makeToggle(Content, "Fly", "fly")
            makeSlider(Content, "Vitesse Fly", "flySpeed", 10, 200, true)
            makeToggle(Content, "Speed Hack", "speedEnabled")
            makeSlider(Content, "Multiplicateur Vitesse", "speedValue", 1, 10, false)
            makeToggle(Content, "High Jump", "jumpEnabled")
            makeSlider(Content, "Jump Power", "jumpValue", 50, 300, true)

        elseif tabName == "Visual" then
            makeSection(Content, "Effets Visuels")
            makeToggle(Content, "Bloom", "bloomEnabled", function(v)
                local bloom = Lighting:FindFirstChildOfClass("BloomEffect")
                if not bloom then bloom = Instance.new("BloomEffect"); bloom.Parent = Lighting end
                bloom.Enabled = v
            end)
            makeSlider(Content, "Bloom Intensité", "bloomIntensity", 0, 3, false, function(v)
                local bloom = Lighting:FindFirstChildOfClass("BloomEffect")
                if bloom then bloom.Intensity = v end
            end)
            makeSlider(Content, "Bloom Taille", "bloomSize", 0, 100, true, function(v)
                local bloom = Lighting:FindFirstChildOfClass("BloomEffect")
                if bloom then bloom.Size = v end
            end)
            makeToggle(Content, "Color Correction", "colorCorrectionEnabled", function(v)
                local cc = Lighting:FindFirstChildOfClass("ColorCorrectionEffect")
                if not cc then cc = Instance.new("ColorCorrectionEffect"); cc.Parent = Lighting end
                cc.Enabled = v
            end)
            makeToggle(Content, "Fullbright", "fullbright", function(v)
                if v then
                    Lighting.Brightness = 2
                    Lighting.OutdoorAmbient = Color3.fromRGB(255,255,255)
                else
                    Lighting.Brightness = 1
                    Lighting.OutdoorAmbient = Color3.fromRGB(128,128,128)
                end
            end)
            makeSection(Content, "FPS & Protection")
            makeToggle(Content, "FPS Boost", "fpsBoost", function(v)
                if v then
                    settings().Rendering.QualityLevel = 1
                    for _, eff in pairs(Lighting:GetChildren()) do
                        if eff:IsA("BloomEffect") or eff:IsA("ColorCorrectionEffect") or eff:IsA("SunRaysEffect") or eff:IsA("DepthOfFieldEffect") then
                            eff.Enabled = false
                        end
                    end
                    Lighting.GlobalShadows = false
                    Lighting.Brightness = 2
                    Lighting.OutdoorAmbient = Color3.fromRGB(255,255,255)
                    notify("ZNK Hub", "FPS Boost activé - Graphismes minimum", 2)
                else
                    settings().Rendering.QualityLevel = 10
                    Lighting.GlobalShadows = true
                    Lighting.Brightness = 1
                    Lighting.OutdoorAmbient = Color3.fromRGB(128,128,128)
                    notify("ZNK Hub", "FPS Boost désactivé - Graphismes restaurés", 2)
                end
            end)
            makeToggle(Content, "Stream Protection (Cache UI)", "streamProtect", function(v)
                if v then
                    Main.Visible = false
                    notify("ZNK Hub", "Stream Protection activé - UI cachée", 2)
                else
                    Main.Visible = true
                    notify("ZNK Hub", "Stream Protection désactivé - UI visible", 2)
                end
            end)
            makeToggle(Content, "Cacher Nom", "hideName", function(v)
                if not _G.ZNKOriginalName then
                    _G.ZNKOriginalName = LocalPlayer.DisplayName
                end
                if v then
                    LocalPlayer.DisplayName = "Hidden"
                else
                    LocalPlayer.DisplayName = _G.ZNKOriginalName or LocalPlayer.Name
                end
            end)

        elseif tabName == "Others" then
            makeSection(Content, "Anti AFK")
            makeToggle(Content, "Anti AFK", "antiAFK")

            makeSection(Content, "Touche Minimize")
            local keyNames = {"RightControl","Insert","Home","Delete","End","PageUp","PageDown","F1","F2","F3","F4","F5","F6","F7","F8","F9","F10","F11","F12"}
            local keyRow = Instance.new("Frame", Content)
            keyRow.Size = UDim2.new(1,0,0,36); keyRow.BackgroundColor3 = panelSoft; keyRow.BorderSizePixel=0
            Instance.new("UICorner", keyRow).CornerRadius = UDim.new(0,8)
            local keyLbl = Instance.new("TextLabel", keyRow)
            keyLbl.Size = UDim2.new(0.5,0,1,0); keyLbl.Position = UDim2.new(0,10,0,0)
            keyLbl.BackgroundTransparency=1; keyLbl.Text="Touche Minimize"
            keyLbl.Font=Enum.Font.GothamBold; keyLbl.TextSize=12; keyLbl.TextColor3=Color3.fromRGB(220,215,235)
            keyLbl.TextXAlignment=Enum.TextXAlignment.Left
            local curKeyName = tostring(settings.minimizeKey):gsub("Enum.KeyCode.","")
            local keyDD = Instance.new("TextButton", keyRow)
            keyDD.Size = UDim2.new(0.4,0,0,24); keyDD.Position = UDim2.new(0.57,0,0.5,-12)
            keyDD.BackgroundColor3 = Color3.fromRGB(30,28,42); keyDD.Text = curKeyName
            keyDD.Font=Enum.Font.GothamBold; keyDD.TextSize=11; keyDD.TextColor3=currentTheme
            keyDD.AutoButtonColor=false; keyDD.BorderSizePixel=0
            Instance.new("UICorner", keyDD).CornerRadius=UDim.new(0,6)
            keyDD.MouseButton1Click:Connect(function()
                local ddGui2 = Instance.new("ScreenGui")
                ddGui2.ResetOnSpawn=false; ddGui2.DisplayOrder=99999999
                pcall(function() if gethui then ddGui2.Parent=gethui() else ddGui2.Parent=CoreGui end end)
                local ddF = Instance.new("Frame", ddGui2)
                ddF.Size = UDim2.new(0,160,0,#keyNames*30+8); ddF.Position = UDim2.new(0.5,-80,0.5,-100)
                ddF.BackgroundColor3=Color3.fromRGB(22,20,32); ddF.BorderSizePixel=0; ddF.Active=true; ddF.Draggable=true
                Instance.new("UICorner", ddF).CornerRadius=UDim.new(0,8)
                Instance.new("UIStroke", ddF).Color=currentTheme
                local ddScroll = Instance.new("ScrollingFrame", ddF)
                ddScroll.Size=UDim2.new(1,-8,1,-8); ddScroll.Position=UDim2.new(0,4,0,4)
                ddScroll.BackgroundTransparency=1; ddScroll.BorderSizePixel=0; ddScroll.ScrollBarThickness=3
                ddScroll.ScrollBarImageColor3=currentTheme; ddScroll.CanvasSize=UDim2.new(0,0,0,#keyNames*30)
                local ddList2 = Instance.new("UIListLayout", ddScroll)
                ddList2.Padding=UDim.new(0,2); ddList2.SortOrder=Enum.SortOrder.LayoutOrder
                for _, kn in ipairs(keyNames) do
                    local kBtn = Instance.new("TextButton", ddScroll)
                    kBtn.Size=UDim2.new(1,0,0,28); kBtn.BackgroundColor3=Color3.fromRGB(30,28,42)
                    kBtn.Text=kn; kBtn.Font=Enum.Font.GothamBold; kBtn.TextSize=11
                    kBtn.TextColor3=Color3.fromRGB(200,195,215); kBtn.AutoButtonColor=false; kBtn.BorderSizePixel=0
                    Instance.new("UICorner", kBtn).CornerRadius=UDim.new(0,5)
                    kBtn.MouseButton1Click:Connect(function()
                        local ok, keyCode = pcall(function() return Enum.KeyCode[kn] end)
                        if ok then
                            settings.minimizeKey = keyCode
                            keyDD.Text = kn
                        end
                        ddGui2:Destroy()
                    end)
                end
                local closeBtn2 = Instance.new("TextButton", ddGui2)
                closeBtn2.Size=UDim2.new(1,0,1,0); closeBtn2.BackgroundTransparency=1; closeBtn2.Text=""
                closeBtn2.ZIndex=ddF.ZIndex-1
                closeBtn2.MouseButton1Click:Connect(function() ddGui2:Destroy() end)
            end)

            makeSection(Content, "Thème / Couleur UI")
            makeColorPicker(Content, "Couleur du thème", "espColor", function(newColor)
                -- Apply theme color (visual preview only, full apply on restart)
                MainStroke.Color = newColor
                currentTheme = newColor
                notify("ZNK Hub", "Thème mis à jour (redémarre pour appliquer complètement)", 3)
            end)

            makeSection(Content, "Session")
            local logoutRow = Instance.new("Frame", Content)
            logoutRow.Size = UDim2.new(1,0,0,36); logoutRow.BackgroundColor3 = Color3.fromRGB(38,18,22); logoutRow.BorderSizePixel=0
            Instance.new("UICorner", logoutRow).CornerRadius = UDim.new(0,8)
            local logoutBtn = Instance.new("TextButton", logoutRow)
            logoutBtn.Size=UDim2.new(1,0,1,0); logoutBtn.BackgroundTransparency=1; logoutBtn.Text="🚪 Déconnexion & Sauvegarde"
            logoutBtn.Font=Enum.Font.GothamBold; logoutBtn.TextSize=12; logoutBtn.TextColor3=Color3.fromRGB(255,100,100)
            logoutBtn.MouseButton1Click:Connect(function()
                saveCurrentAccount()
                forceDisconnect("Déconnexion manuelle.")
            end)
        end
    end)
end

