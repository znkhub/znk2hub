-- SAUVEGARDE PAR COMPTE
-- ============================================================
local function getAccountSaveFile(username)
    return SAVES_FOLDER .. "/" .. username:lower():gsub("[^%w_%-]","_") .. ".json"
end
local function loadAccountSave(username)
    if not username or username == "" then return nil end
    local file = getAccountSaveFile(username)
    local raw  = safeRead(file)
    if not raw then return nil end
    local ok, data = pcall(HttpService.JSONDecode, HttpService, raw)
    return (ok and data) or nil
end
local function saveAccountSave(username, data)
    if not username or username == "" then return end
    pcall(function()
        if makefolder then pcall(function() makefolder(SAVES_FOLDER) end) end
    end)
    local file = getAccountSaveFile(username)
    local ok, encoded = pcall(HttpService.JSONEncode, HttpService, data)
    if ok then safeWrite(file, encoded) end
end
local function deleteAccountSave(username)
    if not username or username == "" then return end
    safeDelete(getAccountSaveFile(username))
end

