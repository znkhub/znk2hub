                    Name.TextColor3 = settings.espColor
                    Name.Position = UDim2.new(0, Pos.X, 0, Pos.Y-h/2-9)

                    Distance.Visible = false
                    Weapon.Text = ""; Weapon.Visible = settings.espWeapons
                    Weapon.Position = UDim2.new(0, Pos.X, 0, Pos.Y+h/2+8)
                else
                    HideESP()
                end
            else
                HideESP()
            end
        end)
    end

    for _, v in pairs(PlayersESP:GetPlayers()) do
        if v ~= lplayer then coroutine.wrap(spawnESP)(v) end
    end
