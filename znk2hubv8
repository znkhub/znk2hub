local function makeTab(label, icon)
    local Page = Instance.new("ScrollingFrame", ContentArea)
    Page.Size = UDim2.new(1, 0, 1, 0); Page.BackgroundTransparency = 1; Page.BorderSizePixel = 0
    Page.ScrollBarThickness = 3; Page.ScrollBarImageColor3 = currentTheme
    Page.CanvasSize = UDim2.new(0, 0, 0, 0); Page.Visible = false
    local PageLayout = Instance.new("UIListLayout", Page)
    PageLayout.Padding = UDim.new(0, 6); PageLayout.SortOrder = Enum.SortOrder.LayoutOrder
    local PagePad = Instance.new("UIPadding", Page)
    PagePad.PaddingTop = UDim.new(0, 8); PagePad.PaddingLeft = UDim.new(0, 8); PagePad.PaddingRight = UDim.new(0, 8)
    PageLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        Page.CanvasSize = UDim2.new(0, 0, 0, PageLayout.AbsoluteContentSize.Y + 16)
    end)
    local TBtn = Instance.new("TextButton", TabBar)
    TBtn.Size = UDim2.new(0, 86, 0, 28); TBtn.BackgroundColor3 = Color3.fromRGB(20, 18, 28)
    TBtn.Text = icon.." "..label; TBtn.Font = Enum.Font.GothamBold; TBtn.TextSize = 11
    TBtn.TextColor3 = textMuted; TBtn.AutoButtonColor = false
    Instance.new("UICorner", TBtn).CornerRadius = UDim.new(0, 6)
    table.insert(tabBtns, TBtn); table.insert(tabPages, Page)
    TBtn.MouseButton1Click:Connect(function()
        currentTab = Page
        for _, p in pairs(tabPages) do p.Visible = false end
        for _, b in pairs(tabBtns) do b.BackgroundColor3 = Color3.fromRGB(20, 18, 28); b.TextColor3 = textMuted end
        Page.Visible = true; TBtn.BackgroundColor3 = currentTheme; TBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    end)
    return Page, TBtn
end

