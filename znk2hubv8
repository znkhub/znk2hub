local function forceDisconnect(reason)
    deleteSession()
    removeFromWhitelist(loggedUsername)
    loginVerified      = false
    loggedUsername     = ""
    currentSessionData = nil
    if ScreenGui and ScreenGui.Parent then ScreenGui:Destroy() end
    if MinimizeWidget and MinimizeWidget.Parent then MinimizeWidget:Destroy() end
    notify("ZNK Hub", reason or "Accès révoqué. Déconnexion.", 3)
    task.delay(1, function() createLoginScreen() end)
end

-- ============================================================
-- WATCHER TIMER
-- ============================================================
local function startTimerWatcher()
    task.spawn(function()
        while loginVerified do
            task.wait(5)
            if currentSessionData and isKeyExpiredForAccount(currentSessionData) then
                forceDisconnect("Votre key a expiré. Accès révoqué.")
                return
            end
            if loggedUsername ~= "" then
                local accounts = loadAccounts()
                if not accounts[loggedUsername:lower()] then
                    forceDisconnect("Votre compte a été supprimé par l'admin.")
                    return
                end
            end
        end
    end)
end

