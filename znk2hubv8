local function isKeybindPressed(kb)
    if not kb then return false end
    if kb.type == "key" then
        return UserInputService:IsKeyDown(kb.code)
    elseif kb.type == "mouse" then
        return UserInputService:IsMouseButtonPressed(kb.code)
    end
    return false
end

local function keybindToString(kb)
    if not kb then return "Aucune" end
    if kb.type == "key" then
        local name = tostring(kb.code)
        return name:gsub("Enum%.KeyCode%.", "")
    elseif kb.type == "mouse" then
        local name = tostring(kb.code)
        name = name:gsub("Enum%.UserInputType%.", "")
        if name == "MouseButton1" then return "Clic Gauche"
        elseif name == "MouseButton2" then return "Clic Droit"
        elseif name == "MouseButton3" then return "Clic Milieu"
        end
        return name
    end
    return "?"
end

