        if accountExists(username) then
            local ok, userData = checkAccount(username, password)
            if ok then
                StatusMsg.Text = "✅ Connexion réussie !"; StatusMsg.TextColor3 = Color3.fromRGB(50, 200, 100)
                task.wait(0.3); finishLogin(username, userData)
            else
                StatusMsg.Text = "Mot de passe incorrect"; StatusMsg.TextColor3 = Color3.fromRGB(220, 80, 80); animateShake()
            end
            return
        end
        if key ~= "" and isKeyValid(key) then
            local userData = saveAccount(username, password, key)
            StatusMsg.Text = "✅ Compte créé & connecté !"; StatusMsg.TextColor3 = Color3.fromRGB(50, 200, 100)
            task.wait(0.3); finishLogin(username, userData); return
        end
        StatusMsg.Text = "Compte inconnu. Utilisez une key pour créer un compte."; StatusMsg.TextColor3 = Color3.fromRGB(220, 80, 80); animateShake()
    end

    local function doRegister()
        local username = UsernameInput.Text:gsub("%s",""); local password = PasswordInput.Text; local key = KeyInput.Text:gsub("%s","")
        if username == "" or password == "" then StatusMsg.Text = "Pseudo et mot de passe requis"; StatusMsg.TextColor3 = Color3.fromRGB(220, 80, 80); animateShake(); return end
        if #username < 3 then StatusMsg.Text = "Pseudo trop court (min 3)"; StatusMsg.TextColor3 = Color3.fromRGB(220, 80, 80); animateShake(); return end
        if #password < 4 then StatusMsg.Text = "Mot de passe trop court (min 4)"; StatusMsg.TextColor3 = Color3.fromRGB(220, 80, 80); animateShake(); return end
        if accountExists(username) then StatusMsg.Text = "Ce pseudo est déjà pris !"; StatusMsg.TextColor3 = Color3.fromRGB(220, 80, 80); animateShake(); return end
        if not isKeyValid(key) then
            StatusMsg.Text = "Key invalide ou expirée !"; StatusMsg.TextColor3 = Color3.fromRGB(220, 80, 80)
            TweenService:Create(KeyStroke, TweenInfo.new(0.15), {Color=Color3.fromRGB(220, 40, 40)}):Play()
            task.delay(0.8, function() TweenService:Create(KeyStroke, TweenInfo.new(0.2), {Color=Color3.fromRGB(70, 55, 85)}):Play() end)
