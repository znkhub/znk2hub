        end
        local userData = saveAccount(username, password, key)
        StatusMsg.Text = "✅ Compte créé !"; StatusMsg.TextColor3 = Color3.fromRGB(50, 200, 100)
        task.wait(0.3); finishLogin(username, userData)
    end

