-- Détermine le chemin bureau selon l'exploit
local function getDesktopPath()
    -- Tentative getspecialfolderpath (Synapse X, KRNL récent, Fluxus)
    if getspecialfolderpath then
        local ok, p = pcall(getspecialfolderpath, "desktop")
        if ok and p and p ~= "" then
            return p .. "\\" .. DESKTOP_SAVE_FILENAME
        end
    end
    -- Fallback: workspace/desktop via chemin relatif connu de certains exploits
    -- Certains exploits exposent un dossier "Desktop" dans leur répertoire
    local candidates = {
        "Desktop\\" .. DESKTOP_SAVE_FILENAME,
        "desktop\\" .. DESKTOP_SAVE_FILENAME,
        DESKTOP_SAVE_FILENAME, -- fallback même dossier
    }
    for _, c in ipairs(candidates) do
        if isfile and isfile(c) then return c end
    end
    -- Retourne le chemin standard même s'il n'existe pas encore (pour création)
    if getspecialfolderpath then
        local ok, p = pcall(getspecialfolderpath, "desktop")
        if ok and p then return p .. "\\" .. DESKTOP_SAVE_FILENAME end
    end
    return DESKTOP_SAVE_FILENAME
end

local function desktopFileExists()
    local path = getDesktopPath()
    if isfile and isfile(path) then return true, path end
    return false, path
end

local function loadDesktopSave()
    local exists, path = desktopFileExists()
    if not exists then return nil, "Fichier bureau introuvable" end
    local raw = safeRead(path)
    if not raw then return nil, "Fichier vide ou illisible" end
    local ok, data = pcall(HttpService.JSONDecode, HttpService, raw)
    if not ok then return nil, "Fichier corrompu" end
    return data, "OK"
end

local function writeDesktopSave(data)
    local exists, path = desktopFileExists()
    -- On peut écrire même si le fichier n'existe pas encore (première création)
    -- Mais si le fichier n'a jamais été créé/téléchargé, on refuse
    if not exists then
        -- Tenter de le créer automatiquement si on est en mode création initiale
        return false, "Fichier bureau requis. Téléchargez-le d'abord."
    end
    local ok, encoded = pcall(HttpService.JSONEncode, HttpService, data)
    if not ok then return false, "Erreur encodage" end
    safeWrite(path, encoded)
    return true, path
end

-- Création initiale du fichier bureau (premier téléchargement)
local function createDesktopSaveFile()
    local _, path = desktopFileExists()
    local initialData = {
        _znk_magic = "ZNK_HUB_SAVE_FILE_DO_NOT_RENAME",
        _version = 1,
        settings = {},
        savedAt = os.time and os.time() or 0,
        username = ""
    }
    local ok, encoded = pcall(HttpService.JSONEncode, HttpService, initialData)
    if ok then
        safeWrite(path, encoded)
        return true, path
    end
    return false, path
end

-- Télécharge/exporte le fichier de sauvegarde (via setclipboard du chemin ou writefile)
local function downloadDesktopSaveFile(settingsData, username)
    -- On écrit dans le même dossier que les autres fichiers exploit avec le nom spécial
    -- ET on essaie de l'écrire sur le bureau via getspecialfolderpath
    local data = {
        _znk_magic = "ZNK_HUB_SAVE_FILE_DO_NOT_RENAME",
        _version = 1,
        settings = settingsData or {},
        savedAt = os.time and os.time() or 0,
        username = username or ""
    }
    local ok, encoded = pcall(HttpService.JSONEncode, HttpService, data)
    if not ok then return false, "Erreur encodage" end

    local paths = {}
    -- Chemin bureau via getspecialfolderpath
    if getspecialfolderpath then
        local sok, p = pcall(getspecialfolderpath, "desktop")
        if sok and p and p ~= "" then
            table.insert(paths, p .. "\\" .. DESKTOP_SAVE_FILENAME)
        end
    end
    -- Dossier exploit lui-même
    table.insert(paths, DESKTOP_SAVE_FILENAME)

    local written = false
    local lastPath = ""
    for _, path in ipairs(paths) do
        pcall(writefile, path, encoded)
        if isfile and isfile(path) then
            written = true; lastPath = path
        end
    end

    -- Copier le contenu dans le presse-papier aussi
    pcall(function()
        if setclipboard then setclipboard(encoded) end
    end)

    return written, lastPath
end

