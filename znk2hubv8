-- ★ Fonction minimize/restore
local function toggleMinimize()
    if not ScreenGui or not ScreenGui.Parent then return end
    local mf = ScreenGui:FindFirstChild("MainFrame")
    if not mf then return end

    isMinimized = not isMinimized

    if isMinimized then
        -- Cacher le hub principal
        TweenService:Create(mf, TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
            Size = UDim2.new(0, MAIN_FRAME_WIDTH, 0, 0)
        }):Play()
        task.wait(0.26)
        mf.Visible = false
        -- Afficher le petit rectangle
        MiniFrame.Visible = true
        MiniFrame.Size = UDim2.new(0, 0, 0, 34)
        TweenService:Create(MiniFrame, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, 130, 0, 34)
        }):Play()
    else
        -- Cacher le widget mini
        TweenService:Create(MiniFrame, TweenInfo.new(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
            Size = UDim2.new(0, 0, 0, 34)
        }):Play()
        task.wait(0.22)
        MiniFrame.Visible = false
        -- Restaurer le hub
        mf.Visible = true
        mf.Size = UDim2.new(0, MAIN_FRAME_WIDTH, 0, 0)
        TweenService:Create(mf, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, MAIN_FRAME_WIDTH, 0, MAIN_FRAME_FULL_HEIGHT)
        }):Play()
    end
end

-- ★ Écoute InputBegan pour minimize ET aim toggle keybind ★
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end

    -- Minimize keybind
    local mkb = settings.minimizeKeybind
    if mkb then
        local matchMin = false
        if mkb.type == "key" and input.KeyCode == mkb.code then matchMin = true end
        if mkb.type == "mouse" and input.UserInputType == mkb.code then matchMin = true end
        if matchMin then
            task.spawn(toggleMinimize)
            return
        end
    end

    -- Aim toggle keybind
    local akb = settings.aimToggleKeybind
    if akb and not aimToggleDebounce then
        local matchAim = false
        if akb.type == "key" and input.KeyCode == akb.code then matchAim = true end
        if akb.type == "mouse" and input.UserInputType == akb.code then matchAim = true end
        if matchAim then
            aimToggleDebounce = true
            settings.aimEnabled = not settings.aimEnabled
            notify("ZNK Hub", "Aim Assist: "..(settings.aimEnabled and "✅ ON" or "❌ OFF"), 1.5)
            task.delay(0.3, function() aimToggleDebounce = false end)
        end
    end
end)

